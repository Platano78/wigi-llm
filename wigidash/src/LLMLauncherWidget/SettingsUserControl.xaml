<UserControl x:Class="LLMLauncherWidget.SettingsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#303030"
             Foreground="White"
             FontSize="12">
    <ScrollViewer>
        <StackPanel Margin="10">
            <TextBlock Text="LLM Launcher Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#00C8FF"/>
            
            <GroupBox Header="Server Status" Foreground="White" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Port 8081: " Margin="0,5" Foreground="#CCCCCC"/>
                    <TextBlock x:Name="StatusText" Text="Checking..." Margin="20,0,0,10" Foreground="#FFFF00"/>
                    <Button Content="Refresh Status" Click="OnRefreshStatus" Padding="10,5" Background="#0099FF" Foreground="White" Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            
            <GroupBox Header="Configuration" Foreground="White" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock TextWrapping="Wrap" Margin="0,5" Foreground="#CCCCCC">
                        Buttons are configured via <Run FontWeight="Bold">buttons.json</Run> in this widget's directory.
                        Edit that file to add, remove, or modify buttons. Restart WigiDash Manager to reload.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,10,0,5" Foreground="#CCCCCC">
                        Configuration reference:
                        <Hyperlink NavigateUri="https://github.com/Platano78/wigi-llm">github.com/Platano78/wigi-llm</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Visual Feedback" Foreground="White" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="• Blue Pulse: Server launching" Margin="0,5" Foreground="#00D4FF"/>
                    <TextBlock Text="• Green Flash: Server running" Margin="0,5" Foreground="#00FF00"/>
                    <TextBlock Text="• Red Flash: Error occurred" Margin="0,5" Foreground="#FF3333"/>
                    <TextBlock Text="• Green Border: Port in use" Margin="0,5" Foreground="#00FF00"/>
                </StackPanel>
            </GroupBox>
            
            <Button Content="Reset to Defaults" Click="OnResetDefaults" Padding="10,5" Background="#FF6600" Foreground="White" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

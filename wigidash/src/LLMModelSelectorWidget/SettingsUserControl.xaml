<UserControl x:Class="LLMModelSelectorWidget.SettingsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="350">
    <StackPanel Margin="15" Background="#1E1E1E">
        <Label Content="LLM Model Selector Settings" FontWeight="Bold" FontSize="14" Foreground="White" Margin="0,0,0,10"/>

        <Border BorderBrush="#404040" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>

        <!-- Router URL -->
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Router URL:" Foreground="#B0B0B0" VerticalAlignment="Center"/>
            <TextBox x:Name="RouterUrlBox" Grid.Column="1" TextChanged="RouterUrlBox_TextChanged"
                     Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="5"/>
        </Grid>

        <!-- Polling Interval -->
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Polling Interval (ms):" Foreground="#B0B0B0" VerticalAlignment="Center"/>
            <TextBox x:Name="PollingIntervalBox" Grid.Column="1" TextChanged="PollingIntervalBox_TextChanged"
                     Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="5"/>
        </Grid>

        <!-- Info text -->
        <TextBlock TextWrapping="Wrap" Foreground="#808080" FontSize="10" Margin="0,0,0,15">
            Update interval for polling model status from the router API.
        </TextBlock>

        <!-- Expected API format -->
        <Label Content="Expected API Response:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#B0B0B0" TextWrapping="Wrap">
{
  "models": [...],
  "loaded": ["agents-qwen3-14b", "coding-reap25b"]
}
            </TextBlock>
        </Border>

        <!-- Available Models -->
        <Label Content="Available Models:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="10" Margin="0,0,0,10">
            <TextBlock FontFamily="Consolas" FontSize="9" Foreground="#B0B0B0" TextWrapping="Wrap">
• agents-qwen3-14b (~12GB)
• agents-nemotron (~8GB)
• agents-seed-coder (~5GB)
• coding-reap25b (~15GB)
• coding-seed-coder (~5GB)
• coding-qwen-7b (~5GB)
• fast-deepseek-lite (~6GB)
• fast-qwen14b (~8GB)
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Test Connection" Click="TestConnection_Click" Margin="0,0,10,0"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Padding="15,8"
                    Cursor="Hand"/>
            <Button Content="Apply Settings" Click="Apply_Click"
                    Background="#0E639C" Foreground="White" BorderThickness="0" Padding="15,8"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Status message -->
        <TextBlock x:Name="StatusMessage" Margin="0,10,0,0" Foreground="#4EC9B0" FontSize="10" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
